        {
          "name": "Get Invoice by ID (seeded)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/invoices/{{invoiceId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "invoices", "{{invoiceId}}" ]
            }
          },
          "response": []
        },
        {
          "name": "Generate Duplicate Invoice (409)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{confirmedOrderId}}/invoice",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders", "{{confirmedOrderId}}", "invoice" ]
