{
  "info": {
    "_postman_id": "8f2d6a4e-6d1f-4b3e-9c7a-6b1a2f9d5e10",
    "name": "Pricing Demo API",
    "description": "Products, discounts, orders, and invoices for the pricing-demo Spring Boot API. Uses the seeded demo-data records (see db/changelog/changes/900-seed-demo-data.sql) so most requests work immediately with no setup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "customerId", "value": "99999999-9999-9999-9999-999999999991" },
    { "key": "productIdWidgetStandard", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "productIdGadgetMini", "value": "33333333-3333-3333-3333-333333333333" },
    { "key": "productIdGadgetMax", "value": "44444444-4444-4444-4444-444444444444" },
    { "key": "discountCodeWelcome10", "value": "WELCOME10" },
    { "key": "discountCodeExpired50", "value": "EXPIRED50" },
    { "key": "confirmedOrderId", "value": "66666666-6666-6666-6666-666666666661" },
    { "key": "pendingOrderId", "value": "66666666-6666-6666-6666-666666666662" },
    { "key": "invoiceId", "value": "88888888-8888-8888-8888-888888888881" }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"ACC-STRAP-01\",\n  \"name\": \"Shoulder Strap\",\n  \"unitPrice\": 12.50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "products" ]
            }
          },
          "response": []
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "products" ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product by ID (seeded)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productIdWidgetStandard}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "products", "{{productIdWidgetStandard}}" ]
            }
          },
          "response": []
