              "raw": "{{baseUrl}}/api/orders/{{pendingOrderId}}/invoice",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders", "{{pendingOrderId}}", "invoice" ]
            }
          },
          "response": []
