              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "products", "00000000-0000-0000-0000-000000000000" ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Discounts",
      "item": [
        {
          "name": "Create Discount",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SUMMER15\",\n  \"type\": \"PERCENTAGE\",\n  \"value\": 15,\n  \"minOrderAmount\": 25.00,\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/discounts",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "discounts" ]
            }
          },
          "response": []
        },
        {
          "name": "Get Discount by Code (seeded, active)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/discounts/{{discountCodeWelcome10}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "discounts", "{{discountCodeWelcome10}}" ]
            }
          },
          "response": []
        },
        {
          "name": "Get Discount by Code (seeded, inactive)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/discounts/{{discountCodeExpired50}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "discounts", "{{discountCodeExpired50}}" ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order (seeded products + WELCOME10)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [\n    { \"productId\": \"{{productIdWidgetStandard}}\", \"quantity\": 2 },\n    { \"productId\": \"{{productIdGadgetMini}}\", \"quantity\": 1 }\n  ],\n  \"discountCode\": \"{{discountCodeWelcome10}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders" ]
            }
          },
          "response": []
        },
        {
          "name": "Get Order by ID (seeded, CONFIRMED)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{confirmedOrderId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders", "{{confirmedOrderId}}" ]
            }
          },
          "response": []
        },
        {
          "name": "Confirm Order (seeded, PENDING)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{pendingOrderId}}/confirm",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders", "{{pendingOrderId}}", "confirm" ]
            }
          },
          "response": []
        },
        {
          "name": "Create Order with Inactive Discount (400)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [\n    { \"productId\": \"{{productIdGadgetMax}}\", \"quantity\": 1 }\n  ],\n  \"discountCode\": \"{{discountCodeExpired50}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders" ]
            }
          },
          "response": []
        },
        {
          "name": "Confirm Already-Confirmed Order (409)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{confirmedOrderId}}/confirm",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders", "{{confirmedOrderId}}", "confirm" ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "Generate Invoice for Pending Order (run after Confirm Order)",
          "request": {
            "method": "POST",
