{
  "info": {
    "name": "Pricing Demo API",
    "description": "Endpoints for the Pricing Demo Spring Boot app (products, discounts, orders, invoices).\n\nRun folders top-to-bottom with the Collection Runner for a fully repeatable end-to-end flow: Products/Discounts use random values so they can be created repeatedly, and Orders/Invoices chain off the order just created (Confirm Order -> Get Order -> Generate Invoice -> Get Invoice) so re-running the whole collection never collides with previous runs.\n\nRequires the app running locally (see baseUrl) and the `demo-data` Liquibase context applied so seeded reference data (products, discount code WELCOME10) exists.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "productId", "value": "11111111-1111-1111-1111-111111111111", "type": "string", "description": "Seeded product: Widget Standard" },
    { "key": "productId2", "value": "33333333-3333-3333-3333-333333333333", "type": "string", "description": "Seeded product: Gadget Mini" },
    { "key": "discountCode", "value": "WELCOME10", "type": "string", "description": "Seeded active discount code" },
    { "key": "createdProductId", "value": "", "type": "string" },
    { "key": "createdDiscountCode", "value": "", "type": "string" },
    { "key": "createdOrderId", "value": "", "type": "string" },
    { "key": "createdInvoiceId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Response has product id', function () {",
                  "    pm.expect(body.data.id).to.be.a('string');",
                  "});",
                  "",
                  "pm.collectionVariables.set('createdProductId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"SKU-{{$randomInt}}\",\n  \"name\": \"{{$randomProductName}}\",\n  \"unitPrice\": 24.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "products" ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product by Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has expected id', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.id).to.eql(pm.collectionVariables.get('productId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "products", "{{productId}}" ]
            }
          },
          "response": []
        },
        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response data is an array', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "products" ]
            }
          },
          "response": []
        }
      ]
    },
