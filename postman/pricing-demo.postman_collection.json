                  "});",
                  "",
                  "pm.test('Order is CONFIRMED', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.status).to.eql('CONFIRMED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
