    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Order is PENDING', function () {",
                  "    pm.expect(body.data.status).to.eql('PENDING');",
                  "});",
                  "",
                  "pm.test('Order has the discount code applied', function () {",
                  "    pm.expect(body.data.discountCode).to.eql(pm.collectionVariables.get('discountCode'));",
                  "});",
                  "",
                  "pm.collectionVariables.set('createdOrderId', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{$guid}}\",\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 2 },\n    { \"productId\": \"{{productId2}}\", \"quantity\": 1 }\n  ],\n  \"discountCode\": \"{{discountCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders" ]
            }
          },
          "response": []
        },
        {
          "name": "Remove Discount from Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Discount code is null', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.discountCode).to.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{createdOrderId}}/discount",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders", "{{createdOrderId}}", "discount" ]
            },
            "description": "Only allowed while the order is PENDING. Returns 409 INVALID_ORDER_STATE if the order is already CONFIRMED."
          },
          "response": []
        },
        {
          "name": "Add Discount to Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Discount code is set', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.discountCode).to.eql(pm.collectionVariables.get('discountCode'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"discountCode\": \"{{discountCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{createdOrderId}}/discount",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "orders", "{{createdOrderId}}", "discount" ]
            },
            "description": "Sets (or replaces) the order's discount. Only allowed while the order is PENDING. Returns 400 INVALID_DISCOUNT if the code exists but is inactive, 404 if the code doesn't exist, or 409 INVALID_ORDER_STATE if the order is already CONFIRMED."
          },
          "response": []
        },
        {
          "name": "Confirm Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
